<?xml version="1.0" encoding="UTF-8" ?>
<Shell
    x:Class="NewsApp.AppShell"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:local="clr-namespace:NewsApp"
    Title="NewsApp"
    Shell.BackgroundColor="#0B0F14"
    Shell.ForegroundColor="#E5E7EB"
    Shell.TitleColor="#E5E7EB">

    <Shell.TitleView>
        <HorizontalStackLayout Padding="12,0" VerticalOptions="Center">
            <Label x:Name="ShellTitleLabel"
                   FontAttributes="Bold"
                   FontSize="18"
                   TextColor="#E5E7EB"
                   Text="NewsApp" />
        </HorizontalStackLayout>
    </Shell.TitleView>

    <ShellContent
        Title="Home"
        ContentTemplate="{DataTemplate local:MainPage}"
        Route="MainPage" />

</Shell>
