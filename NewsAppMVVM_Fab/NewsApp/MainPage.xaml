<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="NewsApp.MainPage"
             Title="NewsApp"
             BackgroundColor="{AppThemeBinding Light=#FFFFFF, Dark=#0B0F14}">

    <ContentPage.ToolbarItems>
        <ToolbarItem Text="Rafraîchir" Clicked="OnRefreshClicked" />
    </ContentPage.ToolbarItems>

    <Grid RowDefinitions="*,Auto">
        <!-- IMPORTANT: pas de ScrollView autour d'une CollectionView -->
        <Grid Grid.Row="0" Padding="20" RowDefinitions="Auto,Auto,Auto,Auto,*" RowSpacing="15">
            <Frame Grid.Row="0"
                   BackgroundColor="{AppThemeBinding Light=#F1F3F4, Dark=#111827}"
                   CornerRadius="12"
                   Padding="5"
                   HasShadow="False"
                   BorderColor="{AppThemeBinding Light=#E5E7EB, Dark=#111827}">
                <SearchBar x:Name="SearchBar"
                           Placeholder="Rechercher dans les articles..."
                           TextChanged="OnSearchTextChanged"
                           BackgroundColor="Transparent"
                           TextColor="{AppThemeBinding Light=#111827, Dark=#E5E7EB}"
                           PlaceholderColor="{AppThemeBinding Light=#6B7280, Dark=#9CA3AF}" />
            </Frame>

            <HorizontalStackLayout Grid.Row="1" Spacing="8">
                <Button Text="Politique"
                        Clicked="OnCategoryClicked"
                        CornerRadius="12"
                        Padding="14,10"
                        BackgroundColor="#DBEAFE"
                        TextColor="#1D4ED8" />
                <Button Text="Sport"
                        Clicked="OnCategoryClicked"
                        CornerRadius="12"
                        Padding="14,10"
                        BackgroundColor="#DCFCE7"
                        TextColor="#166534" />
                <Button Text="Cinéma"
                        Clicked="OnCategoryClicked"
                        CornerRadius="12"
                        Padding="14,10"
                        BackgroundColor="#FEE2E2"
                        TextColor="#B91C1C" />
                <Button Text="Technologie"
                        Clicked="OnCategoryClicked"
                        CornerRadius="12"
                        Padding="14,10"
                        BackgroundColor="#FCE7F3"
                        TextColor="#BE185D" />
            </HorizontalStackLayout>

            <Label Grid.Row="2"
                   Text="📴 Hors ligne — données locales"
                   IsVisible="{Binding EstFallback}"
                   BackgroundColor="#FFF3CD"
                   TextColor="#856404"
                   HorizontalTextAlignment="Center"
                   Padding="8" />

            <Label Grid.Row="2"
                   Margin="0,44,0,0"
                   Text="{Binding ApiErreurTexte}"
                   IsVisible="{Binding AfficherApiErreur}"
                   BackgroundColor="#FFF3CD"
                   TextColor="#856404"
                   HorizontalTextAlignment="Center"
                   Padding="8"
                   FontSize="12" />

            <Grid Grid.Row="3" ColumnDefinitions="Auto,*" ColumnSpacing="10" VerticalOptions="Center">
                <ActivityIndicator Grid.Column="0"
                                   IsRunning="{Binding EstEnChargement}"
                                   IsVisible="{Binding EstEnChargement}"
                                   Color="#1E88E5" />
                <Label Grid.Column="1"
                       Text="{Binding ResultatsTexte}"
                       IsVisible="{Binding AfficherResultats}"
                       FontSize="12"
                       VerticalOptions="Center"
                       TextColor="{AppThemeBinding Light=#6B7280, Dark=#9CA3AF}" />
            </Grid>

            <RefreshView Grid.Row="4"
                         IsRefreshing="{Binding EstEnChargement}"
                         Refreshing="OnRefresh">
                <CollectionView x:Name="ArticleCollection"
                                ItemsSource="{Binding Articles}"
                                SelectionMode="Single"
                                SelectionChanged="OnSelectionChanged">
                    <CollectionView.ItemTemplate>
                        <DataTemplate>
                            <Frame Margin="0,0,0,12"
                                   Padding="12"
                                   CornerRadius="16"
                                   HasShadow="True"
                                   BackgroundColor="{AppThemeBinding Light=#FFFFFF, Dark=#0F172A}"
                                   BorderColor="{AppThemeBinding Light=#E5E7EB, Dark=#111827}">
                                <Grid ColumnDefinitions="*,100"
                                      RowDefinitions="Auto,Auto,Auto,Auto"
                                      ColumnSpacing="12"
                                      RowSpacing="6">
                                    <Label Grid.Row="0" Grid.Column="0"
                                           Text="{Binding Titre}"
                                           FontAttributes="Bold"
                                           FontSize="15"
                                           TextColor="{AppThemeBinding Light=#111827, Dark=#E5E7EB}" />

                                    <Label Grid.Row="1" Grid.Column="0"
                                           Text="{Binding Description}"
                                           FontSize="13"
                                           TextColor="{AppThemeBinding Light=#374151, Dark=#CBD5E1}" />

                                    <Label Grid.Row="2" Grid.Column="0"
                                           Text="{Binding SourceEtDate}"
                                           FontSize="11"
                                           TextColor="{AppThemeBinding Light=#6B7280, Dark=#9CA3AF}" />

                                    <Grid Grid.Row="0" Grid.Column="1" Grid.RowSpan="3">
                                        <Image Source="{Binding Image}"
                                               WidthRequest="90"
                                               HeightRequest="70"
                                               Aspect="AspectFill" />
                                    </Grid>

                                    <Grid Grid.Row="3"
                                          Grid.Column="0"
                                          Grid.ColumnSpan="2"
                                          ColumnDefinitions="*,Auto"
                                          ColumnSpacing="10"
                                          VerticalOptions="End">
                                        <Button Grid.Column="0"
                                                Text="Détails"
                                                Clicked="OnDetailsClicked"
                                                CommandParameter="{Binding .}"
                                                CornerRadius="10"
                                                Padding="12,8"
                                                BackgroundColor="{AppThemeBinding Light=#E5E7EB, Dark=#111827}"
                                                TextColor="{AppThemeBinding Light=#111827, Dark=#E5E7EB}"
                                                HorizontalOptions="Start" />

                                        <Label Grid.Column="1"
                                               FontSize="20"
                                               TextColor="#9CA3AF"
                                               Text="♡"
                                               VerticalOptions="Center">
                                            <Label.Triggers>
                                                <DataTrigger TargetType="Label" Binding="{Binding IsFavorite}" Value="True">
                                                    <Setter Property="Text" Value="♥" />
                                                    <Setter Property="TextColor" Value="#E11D48" />
                                                </DataTrigger>
                                            </Label.Triggers>
                                            <Label.GestureRecognizers>
                                                <TapGestureRecognizer Tapped="OnToggleFavoriteTapped"
                                                                      CommandParameter="{Binding .}" />
                                            </Label.GestureRecognizers>
                                        </Label>
                                    </Grid>
                                </Grid>
                            </Frame>
                        </DataTemplate>
                    </CollectionView.ItemTemplate>
                </CollectionView>
            </RefreshView>
        </Grid>

     
        <Grid Grid.Row="1"
              Padding="14,10"
              BackgroundColor="{AppThemeBinding Light=#FFFFFF, Dark=#0B0F14}">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <Border x:Name="HomeTab"
                    Grid.Column="0"
                    Padding="10"
                    BackgroundColor="#E5E7EB"
                    StrokeThickness="0"
                    StrokeShape="RoundRectangle 14"
                    HorizontalOptions="Center">
                <ImageButton Source="home.png"
                             Clicked="OnHomeClicked"
                             BackgroundColor="Transparent"
                             HeightRequest="16"
                             WidthRequest="16"
                             HorizontalOptions="Center" />
            </Border>

            <Border x:Name="FavoritesTab"
                    Grid.Column="1"
                    Padding="10"
                    BackgroundColor="Transparent"
                    StrokeThickness="0"
                    StrokeShape="RoundRectangle 14"
                    HorizontalOptions="Center">
                <ImageButton Source="favoris.png"
                             Clicked="OnFavoritesClicked"
                             BackgroundColor="Transparent"
                             HeightRequest="16"
                             WidthRequest="16"
                             HorizontalOptions="Center" />
            </Border>

            <Border x:Name="ProfileTab"
                    Grid.Column="2"
                    Padding="10"
                    BackgroundColor="Transparent"
                    StrokeThickness="0"
                    StrokeShape="RoundRectangle 14"
                    HorizontalOptions="Center">
                <ImageButton Source="profil.png"
                             Clicked="OnProfileClicked"
                             BackgroundColor="Transparent"
                             HeightRequest="16"
                             WidthRequest="16"
                             HorizontalOptions="Center" />
            </Border>
        </Grid>
    </Grid>

</ContentPage>
