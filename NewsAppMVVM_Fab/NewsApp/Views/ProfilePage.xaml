<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="NewsApp.Views.ProfilePage"
             Title="Profil"
             BackgroundColor="{AppThemeBinding Light=#FFFFFF, Dark=#0B0F14}">

    <Grid RowDefinitions="*,Auto">
        <ScrollView Grid.Row="0">
            <VerticalStackLayout Padding="20" Spacing="12">
                <Label Text="Paramètres"
                       FontSize="24"
                       FontAttributes="Bold"
                       TextColor="{AppThemeBinding Light=#111827, Dark=#E5E7EB}" />

                <Frame Padding="12"
                       CornerRadius="16"
                       HasShadow="True"
                       BackgroundColor="{AppThemeBinding Light=#FFFFFF, Dark=#0F172A}"
                       BorderColor="{AppThemeBinding Light=#E5E7EB, Dark=#111827}">
                    <VerticalStackLayout Spacing="10">
                        <Label Text="Nom d'affichage"
                               FontSize="12"
                               TextColor="{AppThemeBinding Light=#6B7280, Dark=#9CA3AF}" />
                        <Entry x:Name="DisplayNameEntry"
                               Placeholder="Ex: Fabrice"
                               TextColor="{AppThemeBinding Light=#111827, Dark=#E5E7EB}" />

                        <Label Text="Catégorie par défaut"
                               FontSize="12"
                               TextColor="{AppThemeBinding Light=#6B7280, Dark=#9CA3AF}" />
                        <Picker x:Name="DefaultCategoryPicker"
                                Title="Choisir une catégorie" />

                        <Label Text="Pays des actualités"
                               FontSize="12"
                               TextColor="{AppThemeBinding Light=#6B7280, Dark=#9CA3AF}" />
                        <Picker x:Name="CountryPicker"
                                Title="Choisir un pays" />

                        <Grid ColumnDefinitions="*,Auto" VerticalOptions="Center">
                            <Label Grid.Column="0"
                                   Text="Thème sombre"
                                   FontSize="14"
                                   TextColor="{AppThemeBinding Light=#111827, Dark=#E5E7EB}" />
                            <Switch x:Name="DarkThemeSwitch"
                                    Grid.Column="1" />
                        </Grid>

                        <Grid ColumnDefinitions="*,Auto" VerticalOptions="Center">
                            <Label Grid.Column="0"
                                   Text="Notifications"
                                   FontSize="14"
                                   TextColor="{AppThemeBinding Light=#111827, Dark=#E5E7EB}" />
                            <Switch x:Name="NotificationsSwitch"
                                    Grid.Column="1" />
                        </Grid>

                        <Button Text="Enregistrer"
                                Clicked="OnSaveClicked"
                                CornerRadius="12"
                                BackgroundColor="#111827"
                                TextColor="#FFFFFF" />
                    </VerticalStackLayout>
                </Frame>
            </VerticalStackLayout>
        </ScrollView>

        <Grid Grid.Row="1"
              Padding="14,10"
              BackgroundColor="{AppThemeBinding Light=#FFFFFF, Dark=#0B0F14}">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <Border x:Name="HomeTab"
                    Grid.Column="0"
                    Padding="10"
                    BackgroundColor="Transparent"
                    StrokeThickness="0"
                    StrokeShape="RoundRectangle 14"
                    HorizontalOptions="Center">
                <ImageButton Source="home.png"
                             Clicked="OnHomeClicked"
                             BackgroundColor="Transparent"
                             HeightRequest="22"
                             WidthRequest="22"
                             HorizontalOptions="Center" />
            </Border>

            <Border x:Name="FavoritesTab"
                    Grid.Column="1"
                    Padding="10"
                    BackgroundColor="Transparent"
                    StrokeThickness="0"
                    StrokeShape="RoundRectangle 14"
                    HorizontalOptions="Center">
                <ImageButton Source="favoris.png"
                             Clicked="OnFavoritesClicked"
                             BackgroundColor="Transparent"
                             HeightRequest="22"
                             WidthRequest="22"
                             HorizontalOptions="Center" />
            </Border>

            <Border x:Name="ProfileTab"
                    Grid.Column="2"
                    Padding="10"
                    BackgroundColor="#E5E7EB"
                    StrokeThickness="0"
                    StrokeShape="RoundRectangle 14"
                    HorizontalOptions="Center">
                <ImageButton Source="profil.png"
                             Clicked="OnProfileClicked"
                             BackgroundColor="Transparent"
                             HeightRequest="22"
                             WidthRequest="22"
                             HorizontalOptions="Center" />
            </Border>
        </Grid>
    </Grid>

</ContentPage>

