<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="NewsApp.Views.FavoritesPage"
             Title="Favoris"
             BackgroundColor="{AppThemeBinding Light=#FFFFFF, Dark=#0B0F14}">

    <Grid RowDefinitions="*,Auto">
        <VerticalStackLayout Grid.Row="0" Padding="20" Spacing="12">
            <Label Text="Favoris"
                   FontSize="24"
                   FontAttributes="Bold"
                   TextColor="{AppThemeBinding Light=#111827, Dark=#E5E7EB}" />

            <Label Text="Voici les articles favoris."
                   FontSize="14"
                   TextColor="{AppThemeBinding Light=#6B7280, Dark=#9CA3AF}" />
        </VerticalStackLayout>

        <Grid Grid.Row="1"
              Padding="14,10"
              BackgroundColor="{AppThemeBinding Light=#FFFFFF, Dark=#0B0F14}">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <Border x:Name="HomeTab"
                    Grid.Column="0"
                    Padding="10"
                    BackgroundColor="Transparent"
                    StrokeThickness="0"
                    StrokeShape="RoundRectangle 14"
                    HorizontalOptions="Center">
                <ImageButton Source="home.png"
                             Clicked="OnHomeClicked"
                             BackgroundColor="Transparent"
                             HeightRequest="22"
                             WidthRequest="22"
                             HorizontalOptions="Center" />
            </Border>

            <Border x:Name="FavoritesTab"
                    Grid.Column="1"
                    Padding="10"
                    BackgroundColor="#E5E7EB"
                    StrokeThickness="0"
                    StrokeShape="RoundRectangle 14"
                    HorizontalOptions="Center">
                <ImageButton Source="favoris.png"
                             Clicked="OnFavoritesClicked"
                             BackgroundColor="Transparent"
                             HeightRequest="22"
                             WidthRequest="22"
                             HorizontalOptions="Center" />
            </Border>

            <Border x:Name="ProfileTab"
                    Grid.Column="2"
                    Padding="10"
                    BackgroundColor="Transparent"
                    StrokeThickness="0"
                    StrokeShape="RoundRectangle 14"
                    HorizontalOptions="Center">
                <ImageButton Source="profil.png"
                             Clicked="OnProfileClicked"
                             BackgroundColor="Transparent"
                             HeightRequest="22"
                             WidthRequest="22"
                             HorizontalOptions="Center" />
            </Border>
        </Grid>
    </Grid>

</ContentPage>

