<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="NewsApp.Pages.ProfilePage"
             Title="Profil"
             BackgroundColor="{AppThemeBinding Light=#FFFFFF, Dark=#0B0F14}">

    <Grid RowDefinitions="*,Auto">
        <VerticalStackLayout Grid.Row="0" Padding="20" Spacing="12">
            <Label Text="Profil"
                   FontSize="24"
                   FontAttributes="Bold"
                   TextColor="{AppThemeBinding Light=#111827, Dark=#E5E7EB}" />

            <Label Text="Page exemple (navigation demandée par le devoir)."
                   FontSize="14"
                   TextColor="{AppThemeBinding Light=#6B7280, Dark=#9CA3AF}" />
        </VerticalStackLayout>

        <Grid Grid.Row="1"
              Padding="14,10"
              BackgroundColor="{AppThemeBinding Light=#FFFFFF, Dark=#0B0F14}">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <ImageButton Grid.Column="0"
                         Source="home.png"
                         Clicked="OnHomeClicked"
                         BackgroundColor="Transparent"
                         HeightRequest="28"
                         WidthRequest="28"
                         HorizontalOptions="Center" />

            <ImageButton Grid.Column="1"
                         Source="favoris.png"
                         Clicked="OnFavoritesClicked"
                         BackgroundColor="Transparent"
                         HeightRequest="28"
                         WidthRequest="28"
                         HorizontalOptions="Center" />

            <ImageButton Grid.Column="2"
                         Source="profil.png"
                         Clicked="OnProfileClicked"
                         BackgroundColor="Transparent"
                         HeightRequest="28"
                         WidthRequest="28"
                         HorizontalOptions="Center" />
        </Grid>
    </Grid>

</ContentPage>

